<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="activity_balance_trip_enhanced" inherit_id="partner_statement.activity_balance">
        <xpath expr="//thead/tr" position="replace">
            <t t-call="partner_statement_trip_enhancement.statement_fuel_table_header"/>
        </xpath>

        <xpath expr="//tbody/tr[1]" position="replace">
            <tr>
                <td><span t-out="d['prior_day']"/></td>
                <td t-if="is_detailed">Initial Balance</td>
                <td t-else="">Balance Forward</td>
                <td/><td/><td/><td/><td/><td/><td/><td/>
                <td/><td/>
                <td class="amount">
                    <span
                        t-out="currency['balance_forward']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                    />
                </td>
            </tr>
        </xpath>

        <xpath expr="//tbody/tr[2]" position="replace">
            <t t-foreach="currency['lines']" t-as="line">
                <t t-call="partner_statement_trip_enhancement.statement_activity_line_row"/>
            </t>
        </xpath>

        <xpath expr="//tbody/tr[last()]" position="replace">
            <tr>
                <td><span t-out="d['end']"/></td>
                <td>Ending Balance</td>
                <td/><td/><td/><td/><td/><td/><td/><td/>
                <td/><td/>
                <td class="amount">
                    <span
                        t-out="currency['amount_due']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                        style="font-weight: bold;"
                    />
                </td>
            </tr>
        </xpath>
    </template>

    <template id="activity_statement_landscape_assets"
              inherit_id="partner_statement.activity_statement_document">
        <xpath expr="//div[@class='page']" position="before">
            <link rel="stylesheet"
                  href="/partner_statement_trip_enhancement/static/src/scss/statement_landscape.scss"/>
        </xpath>
    </template>
</odoo>
