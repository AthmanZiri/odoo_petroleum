<odoo>
    <template id="activity_balance_trip_enhanced" inherit_id="partner_statement.activity_balance">
        <!-- Replace the table header -->
        <xpath expr="//thead/tr" position="replace">
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Truck Number</th>
                <th>Product</th>
                <th class="amount">Volume</th>
                <th class="amount">Rate</th>
                <th class="amount">Agreed Amount</th>
                <th class="amount">Open Amount</th>
            </tr>
        </xpath>
        
        <!-- Replace the balance forward row -->
        <xpath expr="//tbody/tr[1]" position="replace">
            <tr>
                <td>
                    <span t-out="d['prior_day']" />
                </td>
                <td t-if="is_detailed">Initial Balance</td>
                <td t-else="">Balance Forward</td>
                <td />
                <td />
                <td />
                <td />
                <td />
                <td class="amount">
                    <span
                        t-out="currency['balance_forward']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                    />
                </td>
            </tr>
        </xpath>
        
        <!-- Replace the data rows -->
        <xpath expr="//tbody/tr[2]" position="replace">
            <tr
                t-foreach="currency['lines']"
                t-as="line"
                t-att-class="('statement-blocked ' if line.get('blocked', False) else '') + ('statement-reconciled ' if line['reconciled_line'] else '') + ('statement-outside-date-rank' if line['outside-date-rank'] else '')"
            >
                <td>
                    <span t-out="line['date']" />
                </td>
                <td>
                    <t t-if="line['name'] != '/'">
                        <t t-if="not line['ref'] and line['name']">
                            <span t-out="line['name']" />
                        </t>
                        <t t-if="line['ref'] and not line['name']">
                            <span t-out="line['ref']" />
                        </t>
                        <t t-if="line['ref'] and line['name']">
                            <t
                                t-if="line['name'] not in line['ref'] or line['name'] == line['ref']"
                            >
                                <span t-out="line['name']" />
                            </t>
                            <t t-if="line['ref'] not in line['name']">
                                <span t-out="line['ref']" />
                            </t>
                        </t>
                    </t>
                    <t t-if="line['name'] == '/'">
                        <span t-out="line['ref']" />
                    </t>
                </td>

                <td>
                    <span t-out="line.get('truck_number', '')" />
                </td>
                <td>
                    <span t-out="line.get('product_names', '')" />
                </td>
                <td class="amount">
                    <span t-out="line.get('quantity', 0.0)" />
                </td>
                <td class="amount">
                    <span t-out="line.get('sale_price', '')" />
                </td>
                <td class="amount">
                    <span
                        t-out="line['amount']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                        t-if="not line['reconciled_line']"
                    />
                </td>
                <td class="amount">
                    <span
                        t-out="line['open_amount']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                        t-if="not line['reconciled_line']"
                    />
                </td>
            </tr>
        </xpath>
        
        <!-- Replace the ending balance row -->
        <xpath expr="//tbody/tr[last()]" position="replace">
            <tr>
                <td>
                    <span t-out="d['end']" />
                </td>
                <td>Ending Balance</td>
                <td />
                <td />
                <td />
                <td />
                <td />
                <td class="amount">
                    <span
                        t-out="currency['amount_due']"
                        t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                        style="font-weight: bold;"
                    />
                </td>
            </tr>
        </xpath>
    </template>
</odoo>