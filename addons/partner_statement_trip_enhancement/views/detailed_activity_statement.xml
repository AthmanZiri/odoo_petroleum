<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Remove legacy inherit that duplicated activity_balance (breaks upgrade). -->
    <delete model="ir.ui.view" id="detailed_activity_balance_trip_enhanced"/>

    <!-- Detailed activity reuses activity_balance_trip_enhanced via partner_statement.activity_balance. -->
    <template id="detailed_activity_statement_landscape_assets"
              inherit_id="partner_statement.detailed_activity_statement_document">
        <xpath expr="//div[@class='page']" position="before">
            <link rel="stylesheet"
                  href="/partner_statement_trip_enhancement/static/src/scss/statement_landscape.scss"/>
        </xpath>
    </template>
</odoo>
