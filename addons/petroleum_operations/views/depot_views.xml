<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petroleum_depot_list" model="ir.ui.view">
        <field name="name">petroleum.depot.list</field>
        <field name="model">petroleum.depot</field>
        <field name="arch" type="xml">
            <list string="Depots / Loading Points" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="town"/>
                <field name="partner_id"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_petroleum_depot_form" model="ir.ui.view">
        <field name="name">petroleum.depot.form</field>
        <field name="model">petroleum.depot</field>
        <field name="arch" type="xml">
            <form string="Depot / Loading Point">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="town"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_petroleum_depot" model="ir.actions.act_window">
        <field name="name">Depots / Loading Points</field>
        <field name="res_model">petroleum.depot</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_petroleum_depot"
              name="Depots / Loading Points"
              parent="sale.menu_sale_config"
              action="action_petroleum_depot"
              sequence="50"/>
</odoo>
