<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_petroleum" model="ir.ui.view">
        <field name="name">purchase.order.form.petroleum</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="depot_id"/>
                <field name="epra_no"/>
                <field name="compartment_plan" placeholder="e.g. 2:3:2:3"/>
            </field>
        </field>
    </record>
</odoo>
