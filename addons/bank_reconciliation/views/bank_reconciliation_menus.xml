<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- All-journals bank reconciliation (unmatched by default) -->
    <record id="action_bank_reconciliation" model="ir.actions.act_window">
        <field name="name">Bank Reconciliation</field>
        <field name="res_model">account.bank.statement.line</field>
        <field name="view_mode">kanban,list</field>
        <field name="search_view_id" ref="base_accounting_kit.account_bank_statement_line_view_search"/>
        <field name="domain">[('state', '!=', 'cancel'), ('journal_id.type', 'in', ('bank', 'cash'))]</field>
        <field name="context">{
            'search_default_not_matched': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nothing to reconcile</p>
            <p>Import a bank statement from the Accounting Dashboard, then match transactions here.</p>
        </field>
    </record>

    <record id="action_bank_reconciliation_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="base_accounting_kit.account_bank_statement_line_view_kanban"/>
        <field name="act_window_id" ref="action_bank_reconciliation"/>
    </record>

    <record id="action_bank_reconciliation_view_list" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="base_accounting_kit.account_bank_statement_line_view_tree"/>
        <field name="act_window_id" ref="action_bank_reconciliation"/>
    </record>

    <menuitem id="menu_bank_reconciliation"
              name="Bank Reconciliation"
              parent="account.account_transactions_menu"
              action="action_bank_reconciliation"
              sequence="25"
              groups="account.group_account_basic"/>

    <!-- Closing → Reconcile / Auto-Reconcile -->
    <menuitem id="menu_bank_rec_closing_reconcile"
              name="Reconcile"
              parent="account.account_closing_menu"
              action="action_move_line_to_reconcile"
              sequence="5"
              groups="account.group_account_user"/>

    <menuitem id="menu_bank_rec_closing_auto_reconcile"
              name="Auto-Reconcile"
              parent="account.account_closing_menu"
              action="action_bank_rec_auto_reconcile_wizard"
              sequence="6"
              groups="account.group_account_user"/>
</odoo>
