<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_config_parameter_bank_rec_payment_tolerance" model="ir.config_parameter">
            <field name="key">bank_reconciliation.payment_tolerance</field>
            <field name="value">0.00</field>
        </record>

        <record id="ir_cron_bank_rec_auto_reconcile" model="ir.cron">
            <field name="name">Bank Reconciliation: Auto-reconcile statement lines</field>
            <field name="model_id" ref="account.model_account_bank_statement_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_bank_rec_auto_reconcile(batch_size=50)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
