<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petroleum_data_import_job_list" model="ir.ui.view">
        <field name="name">petroleum.data.import.job.list</field>
        <field name="model">petroleum.data.import.job</field>
        <field name="arch" type="xml">
            <list string="Ledger Import Jobs" create="0" delete="0"
                  decoration-muted="state == 'done'"
                  decoration-info="state == 'pending'">
                <field name="batch_ref"/>
                <field name="name" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-success="state == 'done'"/>
                <field name="progress_label" string="Sections"/>
                <field name="progress_percent" widget="progressbar"
                       invisible="not total_sections"/>
                <field name="total_sections" column_invisible="1"/>
                <field name="cutoff_date" optional="show"/>
                <field name="create_date" string="Started"/>
            </list>
        </field>
    </record>

    <record id="view_petroleum_data_import_job_form" model="ir.ui.view">
        <field name="name">petroleum.data.import.job.form</field>
        <field name="model">petroleum.data.import.job</field>
        <field name="arch" type="xml">
            <form string="Ledger Import Job" create="0" delete="0">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="batch_ref" readonly="1"/></h1>
                        <h2 class="text-muted"><field name="name" readonly="1"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="cutoff_date" readonly="1"/>
                            <field name="opening_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="progress_label" string="Sections processed"/>
                            <field name="progress_percent" widget="progressbar"
                                   invisible="not total_sections"/>
                            <field name="processed_sections" readonly="1"/>
                            <field name="total_sections" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Result" name="result"
                              invisible="state != 'done'">
                            <field name="result_html" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Errors" name="errors"
                              invisible="not error_log">
                            <field name="error_log" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_petroleum_data_import_job_search" model="ir.ui.view">
        <field name="name">petroleum.data.import.job.search</field>
        <field name="model">petroleum.data.import.job</field>
        <field name="arch" type="xml">
            <search string="Ledger Import Jobs">
                <field name="batch_ref"/>
                <field name="name"/>
                <filter string="Running" name="pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="Done" name="done"
                        domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Company" name="group_company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_petroleum_data_import_job" model="ir.actions.act_window">
        <field name="name">Ledger Import Jobs</field>
        <field name="res_model">petroleum.data.import.job</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ledger import jobs yet.
            </p>
            <p>
                Jobs are created when you run
                <b>Petroleum Data Import</b>. While status is
                <b>Running</b>, sections are posted in the background
                (two per minute). When a job is <b>Done</b>, run
                <b>Reconcile Imported Ledgers</b> from Trading Desk.
            </p>
        </field>
    </record>

    <menuitem id="menu_petroleum_data_import_job"
              name="Ledger Import Jobs"
              parent="account.menu_finance_configuration"
              action="action_petroleum_data_import_job"
              sequence="998"/>
</odoo>
