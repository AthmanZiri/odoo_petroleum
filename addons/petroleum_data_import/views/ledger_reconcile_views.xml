<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ledger_reconcile_form" model="ir.ui.view">
        <field name="name">petroleum.ledger.reconcile.form</field>
        <field name="model">petroleum.ledger.reconcile</field>
        <field name="arch" type="xml">
            <form string="Reconcile Imported Ledgers">
                <group invisible="state != 'draft'">
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="reconcile_customers"/>
                    <field name="reconcile_suppliers"/>
                    <field name="only_imported"/>
                    <field name="dry_run"/>
                </group>
                <field name="result_html" invisible="state == 'draft'"/>
                <field name="state" invisible="1"/>
                <footer invisible="state != 'draft'">
                    <button name="action_reconcile" type="object" string="Run FIFO Reconciliation"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button string="Close" special="cancel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ledger_reconcile" model="ir.actions.act_window">
        <field name="name">Reconcile Imported Ledgers</field>
        <field name="res_model">petroleum.ledger.reconcile</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
