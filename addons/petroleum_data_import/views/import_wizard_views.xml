<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petroleum_data_import_form" model="ir.ui.view">
        <field name="name">petroleum.data.import.form</field>
        <field name="model">petroleum.data.import</field>
        <field name="arch" type="xml">
            <form string="Petroleum Data Import">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Excel Ledgers</h1>
                    </div>
                    <group invisible="state != 'draft'">
                        <group string="Scope">
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="cutoff_date"/>
                            <field name="batch_ref"/>
                            <field name="clean_existing"/>
                        </group>
                        <group string="Workbooks">
                            <field name="customers_file" filename="customers_filename"/>
                            <field name="customers_filename" invisible="1"/>
                            <field name="suppliers_file" filename="suppliers_filename"/>
                            <field name="suppliers_filename" invisible="1"/>
                        </group>
                        <group string="Accounting Options">
                            <field name="sale_tax_id"/>
                            <field name="purchase_tax_id"/>
                            <field name="bank_journal_id"/>
                            <field name="misc_journal_id"/>
                        </group>
                    </group>
                    <field name="state" invisible="1"/>
                    <field name="job_id" invisible="1"/>
                    <field name="result_html" invisible="state == 'draft'"
                           readonly="1" nolabel="1"/>
                </sheet>
                <footer>
                    <button name="action_import" type="object" string="Import"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_petroleum_data_import" model="ir.actions.act_window">
        <field name="name">Petroleum Data Import</field>
        <field name="res_model">petroleum.data.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_petroleum_data_import"
              name="Petroleum Data Import"
              parent="account.menu_finance_configuration"
              action="action_petroleum_data_import"
              sequence="999"/>
</odoo>
