    <menuitem id="menu_trip_management_trips"
              name="Trips"
              parent="menu_trip_management_root"
              sequence="30"/>
    
    <!-- Customers Menu -->
    <menuitem id="menu_trip_management_customers"
              name="Customers"
              parent="menu_trip_management_root"
              sequence="40"
              action="base.action_partner_form"/>
    
    <!-- Trucks Menu -->
    <menuitem id="menu_trip_management_trucks"
              name="Trucks"
              parent="menu_trip_management_root"
              sequence="50"/>
    
    <!-- Reporting Menu -->
    <menuitem id="menu_trip_management_reporting"
              name="Reporting"
              parent="menu_trip_management_root"
              sequence="60"/>
