    <menuitem id="menu_trip_management_root"
              name="Trip Management"
              web_icon="sale_order_trip_management,static/description/icon.png"
              sequence="10"/>
    
    <!-- Orders Menu -->
    <menuitem id="menu_trip_management_orders"
              name="Orders"
              parent="menu_trip_management_root"
              sequence="10"/>
              
    <!-- Sale Orders Menu -->
    <menuitem id="menu_trip_management_sale_orders"
              name="Sale Orders"
              parent="menu_trip_management_orders"
              action="sale.action_quotations"
              sequence="10"/>
    
    <!-- Purchases Menu -->
    <menuitem id="menu_trip_management_purchases"
              name="Purchases"
              parent="menu_trip_management_root"
              sequence="20"
