<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Truck Kanban View -->
    <record id="view_truck_management_kanban" model="ir.ui.view">
        <field name="name">truck.management.kanban</field>
        <field name="model">truck.management</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="company_id"/>
                <field name="driver_id"/>
                <field name="capacity"/>
                <field name="is_assigned"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_card">
                                <div class="o_kanban_ribbon bg-danger" t-if="record.is_assigned.raw_value">
                                    <span>Assigned</span>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <ul>
                                            <li><strong>Company: </strong><field name="company_id"/></li>
                                            <li><strong>Driver: </strong><field name="driver_id"/></li>
                                            <li><strong>Capacity: </strong><field name="capacity"/> Litres</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>