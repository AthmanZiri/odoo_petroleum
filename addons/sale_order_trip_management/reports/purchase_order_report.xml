<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Order Report Template -->
    <template id="report_purchaseorder_document_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//div[@id='total']" position="after">
            <div t-if="o.truck_id" class="row mt32 mb32">
                <div class="col-12">
                    <strong>Truck Details:</strong>
                    <table class="table table-sm">
                        <tr>
                            <td><strong>License Number:</strong></td>
                            <td><span t-field="o.truck_id.name"/></td>
                        </tr>
                        <tr t-if="o.driver_name">
                            <td><strong>Driver Name:</strong></td>
                            <td><span t-field="o.driver_name"/></td>
                        </tr>
                        <tr t-if="o.driver_id_no">
                            <td><strong>Driver ID:</strong></td>
                            <td><span t-field="o.driver_id_no"/></td>
                        </tr>
                        <tr t-if="o.transporter_name">
                            <td><strong>Transporter:</strong></td>
                            <td><span t-field="o.transporter_name"/></td>
                        </tr>
                        <tr t-if="o.truck_id.loading_plan">
                            <td><strong>Loading Plan:</strong></td>
                            <td><span t-field="o.truck_id.loading_plan"/></td>
                        </tr>
                    </table>
                </div>
            </div>
        </xpath>
    </template>
</odoo>