<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_deal_payment_form" model="ir.ui.view">
        <field name="name">petroleum.deal.payment.form</field>
        <field name="model">petroleum.deal.payment</field>
        <field name="arch" type="xml">
            <form string="Register Payment">
                <group>
                    <field name="deal_id" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="amount"/>
                    <field name="payment_date"/>
                    <field name="journal_id"/>
                    <field name="memo"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Register" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
