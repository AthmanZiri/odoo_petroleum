<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_deal_revise_sell_price_form" model="ir.ui.view">
        <field name="name">petroleum.deal.revise.sell.price.form</field>
        <field name="model">petroleum.deal.revise.sell.price</field>
        <field name="arch" type="xml">
            <form string="Revise Customer Sell Price">
                <group>
                    <group string="Original Sale">
                        <field name="deal_id" readonly="1"/>
                        <field name="deal_line_id"/>
                        <field name="original_invoice_id"/>
                        <field name="partner_id"/>
                        <field name="product_id"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group string="Price Adjustment">
                        <field name="current_sell_price"/>
                        <field name="new_sell_price"/>
                        <field name="quantity"/>
                        <field name="adjustment_per_litre"/>
                        <field name="adjustment_amount"/>
                        <field name="note"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    A price reduction creates a draft customer credit note.
                    A price increase creates a draft customer debit invoice.
                    Price-only documents affect margin but do not add litres.
                </div>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Create Adjustment" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
