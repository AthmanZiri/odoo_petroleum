<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_desk_bulk_payment_form" model="ir.ui.view">
        <field name="name">petroleum.desk.bulk.payment.form</field>
        <field name="model">petroleum.desk.bulk.payment</field>
        <field name="arch" type="xml">
            <form string="Register Payments">
                <sheet>
                    <div class="oe_title" invisible="state != 'draft'">
                        <h1>Register Payments</h1>
                        <p class="text-muted">
                            Enter how much was received or paid, load open documents,
                            then set how much to apply on each invoice or bill.
                            Drag rows to change allocation order (top first).
                        </p>
                    </div>
                    <group invisible="state != 'draft'">
                        <group string="Payment">
                            <field name="payment_side" widget="radio"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="amount_paid"/>
                            <field name="payment_date"/>
                            <field name="journal_id"/>
                            <field name="memo"/>
                            <field name="group_by_partner"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Filter open documents">
                            <field name="partner_id"
                                   domain="['|', ('customer_rank', '&gt;', 0), ('supplier_rank', '&gt;', 0)]"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="deal_ids" widget="many2many_tags"
                                   domain="[('company_id', '=', company_id), ('state', '!=', 'cancel')]"/>
                        </group>
                    </group>
                    <group invisible="state != 'draft'" class="mb-2">
                        <field name="selected_count" string="Documents"/>
                        <field name="selected_amount" string="Total due (selected)"/>
                        <field name="allocated_amount" string="Allocated"/>
                        <field name="unallocated_amount" string="Unallocated"
                               decoration-warning="unallocated_amount != 0"/>
                    </group>
                    <div invisible="state != 'draft'" class="mb-2">
                        <button name="action_refresh_lines" type="object"
                                string="Load / refresh open documents" class="btn-secondary me-1"/>
                        <button name="action_fill_amount_paid" type="object"
                                string="Amount = total due" class="btn-secondary me-1"/>
                        <button name="action_auto_allocate" type="object"
                                string="Auto-allocate" class="btn-secondary me-1"/>
                        <button name="action_select_all" type="object"
                                string="Select all" class="btn-secondary me-1"/>
                        <button name="action_select_none" type="object"
                                string="Clear selection" class="btn-secondary"/>
                    </div>
                    <field name="line_ids" invisible="state != 'draft'" nolabel="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="sequence" widget="handle"/>
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="move_name" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="deal_id" readonly="1" optional="show"/>
                            <field name="ref" readonly="1" optional="hide"/>
                            <field name="amount_total" readonly="1" optional="hide"/>
                            <field name="amount_residual" readonly="1" sum="Due"/>
                            <field name="amount_to_pay" sum="Apply"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="move_id" column_invisible="True"/>
                            <field name="company_id" column_invisible="True"/>
                        </list>
                    </field>
                    <field name="state" invisible="1"/>
                    <field name="result_html" invisible="state == 'draft'"
                           readonly="1" nolabel="1"/>
                </sheet>
                <footer invisible="state != 'draft'">
                    <button name="action_pay" type="object" string="Register payments"
                            class="btn-primary"
                            invisible="allocated_amount == 0"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button name="action_back_to_draft" type="object"
                            string="Pay more" class="btn-secondary me-1"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_desk_bulk_payment" model="ir.actions.act_window">
        <field name="name">Register Payments</field>
        <field name="res_model">petroleum.desk.bulk.payment</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
