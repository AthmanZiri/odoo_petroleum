<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_deal_link" model="ir.ui.view">
        <field name="name">account.move.form.deal.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <field name="ref" position="after">
                <field name="deal_id" readonly="1"
                       invisible="not deal_id"/>
            </field>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_subtotal']"
                   position="after">
                <field name="petro_margin" string="Margin" sum="Margin"
                       optional="show"
                       column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"
                       decoration-success="petro_margin &gt; 0"
                       decoration-danger="petro_margin &lt; 0"/>
            </xpath>
            <xpath expr="//field[@name='tax_totals']" position="before">
                <field name="petro_margin_total"
                       invisible="move_type not in ('out_invoice', 'out_refund')"
                       decoration-success="petro_margin_total &gt; 0"
                       decoration-danger="petro_margin_total &lt; 0"/>
            </xpath>
        </field>
    </record>

    <record id="view_invoice_tree_deal_link" model="ir.ui.view">
        <field name="name">account.move.list.deal.link</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="invoice_origin" position="after">
                <field name="deal_id" optional="show"/>
                <field name="petro_margin_total" string="Margin" sum="Margin"
                       optional="show"
                       decoration-success="petro_margin_total &gt; 0"
                       decoration-danger="petro_margin_total &lt; 0"/>
            </field>
            <field name="amount_residual_signed" position="attributes">
                <attribute name="optional">show</attribute>
            </field>
        </field>
    </record>

    <record id="view_account_invoice_filter_trading_desk" model="ir.ui.view">
        <field name="name">account.invoice.search.trading.desk</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="deal_id"/>
            </field>
            <filter name="open" position="after">
                <filter name="trading_deal" string="Trading deals"
                        domain="[('deal_id', '!=', False)]"/>
            </filter>
        </field>
    </record>

    <record id="view_account_bill_filter_trading_desk" model="ir.ui.view">
        <field name="name">account.bill.search.trading.desk</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_bill_filter"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="deal_id"/>
            </field>
            <filter name="open" position="after">
                <filter name="trading_deal" string="Trading deals"
                        domain="[('deal_id', '!=', False)]"/>
            </filter>
        </field>
    </record>

    <record id="action_trading_desk_customer_invoices" model="ir.actions.act_window">
        <field name="name">Customer Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,kanban,form,activity</field>
        <field name="view_id" ref="account.view_out_invoice_tree"/>
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="domain">[('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt'))]</field>
        <field name="context">{
            'search_default_out_invoice': 1,
            'search_default_posted': 1,
            'default_move_type': 'out_invoice',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No customer invoices yet.
            </p><p>
                Invoices are created when deals are loaded, or imported from the ledger.
                Use <b>To pay</b> to see open balances, or <b>Register Payments</b> to settle in bulk.
            </p>
        </field>
    </record>

    <record id="action_trading_desk_vendor_bills" model="ir.actions.act_window">
        <field name="name">Vendor Bills</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,kanban,form,activity</field>
        <field name="view_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="search_view_id" ref="account.view_account_bill_filter"/>
        <field name="domain">[('move_type', 'in', ('in_invoice', 'in_refund', 'in_receipt'))]</field>
        <field name="context">{
            'search_default_in_invoice': 1,
            'search_default_posted': 1,
            'default_move_type': 'in_invoice',
            'display_account_trust': True,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vendor bills yet.
            </p><p>
                Bills are created when deals are loaded, or imported from the ledger.
                Use <b>To pay</b> to see open balances, or <b>Register Payments</b> to settle in bulk.
            </p>
        </field>
    </record>
</odoo>
